# Bambu Lab printer connection
PRINTER_HOST=192.168.1.100
BAMBU_SERIAL=your_serial_number
BAMBU_TOKEN=your_access_token

# Slicer (auto-detected as bambustudio)
SLICER_PATH=/Applications/BambuStudio.app/Contents/MacOS/BambuStudio
SLICER_PROFILE=

# Optional client certificate paths for firmware that requires mTLS.
# By default the server looks in ./certs/bambu/ for these filenames.
# BAMBU_CLIENT_CERT=/absolute/path/to/embedded-cert.pem
# BAMBU_CLIENT_KEY=/absolute/path/to/embedded-key.pem

# Transport: stdio (default) or streamable-http
MCP_TRANSPORT=stdio
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=3000
# MCP_HTTP_PATH=/mcp
# MCP_HTTP_ALLOWED_ORIGINS=http://localhost

# Optional Blender bridge
# BLENDER_MCP_BRIDGE_COMMAND=
